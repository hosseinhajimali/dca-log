# Database
DATABASE_URL="postgresql://mydca:mydca_secret@localhost:5432/mydca_db"

# Server
PORT=3001
NODE_ENV=development

# Auth (JWT)
JWT_SECRET=change_this_to_a_long_random_secret_before_production
JWT_EXPIRES_IN=7d

# How often the consolidated cron runs (minutes): price refresh, DCA
# reminders, and announcements. Keep this high (30+) so the Neon database can
# auto-suspend between runs. Low values keep the compute awake 24/7 and burn
# the monthly CU-hour budget.
CRON_INTERVAL_MINUTES=30
