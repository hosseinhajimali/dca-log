# Database
# Matches the credentials in docker-compose.yml (npm run db:up).
DATABASE_URL="postgresql://dcalog:dcalog_secret@localhost:5432/dcalog_db"

# Server
PORT=3001
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
# LOCAL_MODE=true  -> single-user mode: no login, the app auto-enters with one
#                     shared local account. Best for running it yourself.
# LOCAL_MODE=false -> require real login (email/password or Google OAuth below).
LOCAL_MODE=true

# JWT (used whenever a token is issued, including local mode)
JWT_SECRET=lif_is_too_short
JWT_EXPIRES_IN=7d

# How often the consolidated cron runs (minutes): price refresh, DCA
# reminders, and announcements. 5 is fine for a local always-on database.
# Raise it (30+) only on a scale-to-zero host (e.g. Neon) to save compute cost.
CRON_INTERVAL_MINUTES=5

# ── Optional integrations (leave blank to disable) ──────────────────────────
# Frontend origin, used for CORS and OAuth redirects. Defaults to localhost.
# CLIENT_ORIGIN=http://localhost:5173

# CoinGecko: the free public API works with no key. Only set this if you have
# a CoinGecko Pro/Demo key and want higher rate limits.
# COINGECKO_API_KEY=

# Google OAuth: only needed when LOCAL_MODE=false and you want Google login.
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Telegram notifications: only needed if you want DCA reminders sent to a
# Telegram channel. Leave blank to disable.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
