generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  CRYPTO
  METAL
  STOCK
  ETF
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum GoalType {
  ACCUMULATION
  PORTFOLIO_VALUE
  INVESTMENT_COMMITMENT
}

enum NotificationType {
  DCA_REMINDER
  SELL_RULE_MET
  BUYING_RULE_MET
  NEW_FEEDBACK
  ANNOUNCEMENT
}

enum FeedbackCategory {
  COMPLAINT
  FEEDBACK
  LOGIN_ISSUE
  APP_ISSUE
  FEATURE_REQUEST
  OTHER
}

enum DcaFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum RuleStrategyType {
  DRAWDOWN_ATH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash") // null for Google-only accounts
  googleId     String?  @unique @map("google_id")
  name         String?
  currency     String   @default("USD")
  avatar       String?  @map("avatar")
  theme        String   @default("system")
  isAdmin                  Boolean  @default(false) @map("is_admin")
  monthlyDisposableIncome  Float?   @map("monthly_disposable_income")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  assets          Asset[]
  dcaPlans        DcaPlan[]
  transactions    Transaction[]
  goals           Goal[]
  notifications   Notification[]
  feedbacks       Feedback[]
  buyingRuleSets  BuyingRuleSet[]
  sellRuleSets    SellRuleSet[]

  @@map("users")
}

model Asset {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  symbol      String // e.g. "BTC", "ETH", "XAU"
  name        String // e.g. "Bitcoin", "Gold"
  assetType   AssetType @map("asset_type")
  coingeckoId String?   @map("coingecko_id") // for crypto price lookup
  color       String? // optional hex color, e.g. "#f7931a"
  athOverride Float?    @map("ath_override") // user-supplied ATH; overrides auto-fetched value
  createdAt   DateTime  @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dcaPlans        DcaPlan[] // legacy: single-asset plans
  planAllocations PlanAllocation[]
  transactions    Transaction[]
  goals           Goal[]

  @@unique([userId, symbol])
  @@map("assets")
}

model DcaPlan {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  assetId          String?      @map("asset_id") // nullable, kept for legacy plans only
  name             String? // optional label, e.g. "Monthly BTC stack"
  amountUsd        Float        @map("amount_usd") // committed USD to buy each time
  maxBudgetUsd     Float?       @map("max_budget_usd") // optional ceiling for flexible buying
  frequency        DcaFrequency
  intervalDays     Int?         @map("interval_days") // only for CUSTOM frequency
  isActive         Boolean      @default(true) @map("is_active")
  startDate        DateTime     @map("start_date")
  endDate          DateTime?    @map("end_date")
  nextPurchaseDate DateTime?    @map("next_purchase_date")
  scheduledTime    String       @default("08:00") @map("scheduled_time") // HH:MM format
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset             Asset?                @relation(fields: [assetId], references: [id], onDelete: SetNull)
  allocations       PlanAllocation[]
  transactions      Transaction[]
  planBuyingRuleSets PlanBuyingRuleSet[]
  planSellRuleSets   PlanSellRuleSet[]

  @@map("dca_plans")
}

// Each row is one asset's share in a plan. Pcts across a plan must sum to 100.
model PlanAllocation {
  id            String   @id @default(cuid())
  planId        String   @map("plan_id")
  assetId       String   @map("asset_id")
  allocationPct Float    @map("allocation_pct") // 0–100
  createdAt     DateTime @default(now()) @map("created_at")

  plan  DcaPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  asset Asset   @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([planId, assetId])
  @@map("plan_allocations")
}

// ─── Rule Sets ───────────────────────────────────────────────────────────────

// A named, reusable buying strategy (e.g. "Aggressive dip buyer")
model BuyingRuleSet {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  label        String           // e.g. "Conservative", "Aggressive"
  strategyType RuleStrategyType @default(DRAWDOWN_ATH) @map("strategy_type")
  notes        String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows               BuyingRuleSetRow[]
  planBuyingRuleSets PlanBuyingRuleSet[]

  @@map("buying_rule_sets")
}

// One row inside a BuyingRuleSet - params are strategy-specific JSON
model BuyingRuleSetRow {
  id           String   @id @default(cuid())
  ruleSetId    String   @map("rule_set_id")
  params       Json     // e.g. { "minDrawdown": 20, "maxDrawdown": 40 }
  multiplier   Float    @default(1) // buy = multiplier × plan.amountUsd
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  ruleSet BuyingRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@map("buying_rule_set_rows")
}

// Join: which rule sets are assigned to a plan (one marked active)
model PlanBuyingRuleSet {
  id          String   @id @default(cuid())
  planId      String   @map("plan_id")
  ruleSetId   String   @map("rule_set_id")
  isActive    Boolean  @default(false) @map("is_active") // only one per plan should be true
  createdAt   DateTime @default(now()) @map("created_at")

  plan    DcaPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  ruleSet BuyingRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@unique([planId, ruleSetId])
  @@map("plan_buying_rule_sets")
}

// A named, reusable selling strategy
model SellRuleSet {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  label        String
  strategyType RuleStrategyType @default(DRAWDOWN_ATH) @map("strategy_type")
  notes        String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows             SellRuleSetRow[]
  planSellRuleSets PlanSellRuleSet[]

  @@map("sell_rule_sets")
}

model SellRuleSetRow {
  id             String   @id @default(cuid())
  ruleSetId      String   @map("rule_set_id")
  params         Json     // e.g. { "minProfit": 10, "maxProfit": 25 }
  sellAmount     Float    @map("sell_amount")
  sellAmountType String   @default("USD") @map("sell_amount_type") // 'USD' | 'PCT'
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  ruleSet SellRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@map("sell_rule_set_rows")
}

model PlanSellRuleSet {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  ruleSetId String   @map("rule_set_id")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  plan    DcaPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  ruleSet SellRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@unique([planId, ruleSetId])
  @@map("plan_sell_rule_sets")
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  assetId      String          @map("asset_id")
  dcaPlanId    String?         @map("dca_plan_id")
  type         TransactionType @default(BUY)
  amountUsd    Float           @map("amount_usd") // USD spent (buy) or received (sell)
  quantity     Float // units bought or sold
  pricePerUnit Float           @map("price_per_unit")
  purchasedAt  DateTime        @map("purchased_at")
  exchange     String?
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  dcaPlan DcaPlan? @relation(fields: [dcaPlanId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model PriceCache {
  id        String    @id @default(cuid())
  symbol    String    @unique
  priceUsd  Float     @map("price_usd")
  change24h Float?    @map("change_24h") // 24h change %
  marketCap Float?    @map("market_cap")
  ath       Float? // all-time high in USD
  athDate   DateTime? @map("ath_date")
  fetchedAt DateTime  @map("fetched_at")

  @@map("price_cache")
}

model Goal {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  type   GoalType
  name   String
  notes  String?

  // ACCUMULATION
  assetId   String? @map("asset_id")
  targetQty Float?  @map("target_qty")

  // PORTFOLIO_VALUE
  targetValue Float? @map("target_value")

  // INVESTMENT_COMMITMENT
  targetMonthlyAmount Float? @map("target_monthly_amount")

  // Common
  startDate   DateTime? @map("start_date")
  deadline    DateTime?
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@map("goals")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json? // e.g. { planId, ruleId }
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Feedback {
  id        String           @id @default(cuid())
  userId    String?          @map("user_id")
  category  FeedbackCategory
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedbacks")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String   @map("from_currency") // always USD
  toCurrency   String   @map("to_currency")
  rate         Float
  fetchedAt    DateTime @map("fetched_at")

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  message     String
  scheduledAt DateTime? @map("scheduled_at") // null = send immediately
  sentAt      DateTime? @map("sent_at")       // null = not yet sent
  sentCount   Int       @default(0) @map("sent_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("announcements")
}
