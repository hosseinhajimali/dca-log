generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  CRYPTO
  METAL
  STOCK
  ETF
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum GoalType {
  ACCUMULATION
  PORTFOLIO_VALUE
  INVESTMENT_COMMITMENT
}

enum NotificationType {
  DCA_REMINDER
  SELL_RULE_MET
  BUYING_RULE_MET
  NEW_FEEDBACK
}

enum FeedbackCategory {
  COMPLAINT
  FEEDBACK
  LOGIN_ISSUE
  APP_ISSUE
  FEATURE_REQUEST
  OTHER
}

enum DcaFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash") // null for Google-only accounts
  googleId     String?  @unique @map("google_id")
  name         String?
  currency     String   @default("USD")
  avatar       String?  @map("avatar")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assets        Asset[]
  dcaPlans      DcaPlan[]
  transactions  Transaction[]
  goals         Goal[]
  notifications Notification[]
  feedbacks     Feedback[]

  @@map("users")
}

model Asset {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  symbol      String // e.g. "BTC", "ETH", "XAU"
  name        String // e.g. "Bitcoin", "Gold"
  assetType   AssetType @map("asset_type")
  coingeckoId String?   @map("coingecko_id") // for crypto price lookup
  color       String? // optional hex color, e.g. "#f7931a"
  createdAt   DateTime  @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dcaPlans        DcaPlan[] // legacy: single-asset plans
  planAllocations PlanAllocation[]
  transactions    Transaction[]
  goals           Goal[]

  @@unique([userId, symbol])
  @@map("assets")
}

model DcaPlan {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  assetId          String?      @map("asset_id") // nullable, kept for legacy plans only
  name             String? // optional label, e.g. "Monthly BTC stack"
  amountUsd        Float        @map("amount_usd") // total USD to buy each time
  frequency        DcaFrequency
  intervalDays     Int?         @map("interval_days") // only for CUSTOM frequency
  isActive         Boolean      @default(true) @map("is_active")
  perAssetRules    Boolean      @default(false) @map("per_asset_rules") // true = evaluate rules per-asset; false = weighted group average
  startDate        DateTime     @map("start_date")
  endDate          DateTime?    @map("end_date")
  nextPurchaseDate DateTime?    @map("next_purchase_date")
  scheduledTime    String       @default("08:00") @map("scheduled_time") // HH:MM format
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  allocations  PlanAllocation[]
  transactions Transaction[]
  buyingRules  BuyingRule[]
  sellRules    SellRule[]

  @@map("dca_plans")
}

// Each row is one asset's share in a plan. Pcts across a plan must sum to 100.
model PlanAllocation {
  id            String   @id @default(cuid())
  planId        String   @map("plan_id")
  assetId       String   @map("asset_id")
  allocationPct Float    @map("allocation_pct") // 0–100
  createdAt     DateTime @default(now()) @map("created_at")

  plan  DcaPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  asset Asset   @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([planId, assetId])
  @@map("plan_allocations")
}

model BuyingRule {
  id          String   @id @default(cuid())
  dcaPlanId   String   @map("dca_plan_id")
  minDrawdown Float    @map("min_drawdown") // e.g. 20  (positive %, price is this far below ATH)
  maxDrawdown Float    @map("max_drawdown") // e.g. 40
  buyAmount   Float    @map("buy_amount") // USD to buy when drawdown is in this range
  createdAt   DateTime @default(now()) @map("created_at")

  dcaPlan DcaPlan @relation(fields: [dcaPlanId], references: [id], onDelete: Cascade)

  @@map("buying_rules")
}

model SellRule {
  id             String   @id @default(cuid())
  dcaPlanId      String   @map("dca_plan_id")
  minProfit      Float    @map("min_profit") // e.g. 10  (positive %, price is this far above avg buy)
  maxProfit      Float    @map("max_profit") // e.g. 25
  sellAmount     Float    @map("sell_amount") // amount to sell, USD or % depending on sellAmountType
  sellAmountType String   @default("USD") @map("sell_amount_type") // 'USD' | 'PCT'
  createdAt      DateTime @default(now()) @map("created_at")

  dcaPlan DcaPlan @relation(fields: [dcaPlanId], references: [id], onDelete: Cascade)

  @@map("sell_rules")
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  assetId      String          @map("asset_id")
  dcaPlanId    String?         @map("dca_plan_id")
  type         TransactionType @default(BUY)
  amountUsd    Float           @map("amount_usd") // USD spent (buy) or received (sell)
  quantity     Float // units bought or sold
  pricePerUnit Float           @map("price_per_unit")
  purchasedAt  DateTime        @map("purchased_at")
  exchange     String?
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  dcaPlan DcaPlan? @relation(fields: [dcaPlanId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model PriceCache {
  id        String    @id @default(cuid())
  symbol    String    @unique
  priceUsd  Float     @map("price_usd")
  change24h Float?    @map("change_24h") // 24h change %
  marketCap Float?    @map("market_cap")
  ath       Float? // all-time high in USD
  athDate   DateTime? @map("ath_date")
  fetchedAt DateTime  @map("fetched_at")

  @@map("price_cache")
}

model Goal {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  type   GoalType
  name   String
  notes  String?

  // ACCUMULATION
  assetId   String? @map("asset_id")
  targetQty Float?  @map("target_qty")

  // PORTFOLIO_VALUE
  targetValue Float? @map("target_value")

  // INVESTMENT_COMMITMENT
  targetMonthlyAmount Float? @map("target_monthly_amount")

  // Common
  startDate   DateTime? @map("start_date")
  deadline    DateTime?
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@map("goals")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json? // e.g. { planId, ruleId }
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Feedback {
  id        String           @id @default(cuid())
  userId    String?          @map("user_id")
  category  FeedbackCategory
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedbacks")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String   @map("from_currency") // always USD
  toCurrency   String   @map("to_currency")
  rate         Float
  fetchedAt    DateTime @map("fetched_at")

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}
