# Dependencies
node_modules/

# Build output
dist/
build/

# Environment variables — never commit these
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.test
# Keep .env.example if you create one — it documents required variables without secrets

# Prisma
server/prisma/dev.db
server/prisma/dev.db-journal
# Note: server/prisma/migrations/ should be committed — it's migration history

# Uploaded files (avatars, attachments stored on disk)
server/uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# Test coverage
coverage/

# Vite cache (usually inside node_modules/.vite, but just in case)
.vite/
